---
import BaseLayout from '../layouts/BaseLayout.astro';

const systems = [
  {
    name: 'Execution System',
    tagline: 'Notes → Tasks → Feedback loops',
    body: [
      'Everything gets captured immediately — no exceptions. Notes turn into tasks with context, priority, and deadlines.',
      'Weekly reviews close the loop: what shipped, what slipped, what needs to change.',
      'If it\'s not in the system, it doesn\'t exist.',
    ],
    tools: ['Obsidian', 'Linear', 'GitHub', 'Calendar blocks'],
  },
  {
    name: 'AI Workflows',
    tagline: 'Use AI where thinking slows down',
    body: [
      'AI is used where cognitive load is high — drafting, synthesis, iteration. Not for everything. Only where it speeds up thinking.',
      'I decide direction. AI compresses execution.',
      'The goal isn\'t automation — it\'s leverage.',
    ],
    tools: ['Claude', 'GPT-4o', 'Cursor', 'Custom scripts'],
  },
  {
    name: 'Health Optimization',
    tagline: 'Data → Decisions → Adjust',
    body: [
      'CGM, sleep, and movement drive daily decisions. Food timing and activity are adjusted using real data.',
      'Monthly reviews remove what doesn\'t work.',
      'Treat the body like a system, not a guess.',
    ],
    tools: ['Libre CGM', 'Oura Ring', 'Glucose Playbook', 'Training log'],
  },
];
---

<BaseLayout
  title="Systems — Galaxy Kadiyala"
  description="The systems I actually run — execution, AI workflows, and health optimization."
>
  <div class="systems-page">

    <header class="page-header">
      <p class="eyebrow">How I operate</p>
      <h1>Systems</h1>
      <p class="lead">These are the systems I actually run.<br/>Not ideas — what I use daily.</p>
    </header>

    <hr class="rule" />

    <div class="systems-list">
      {systems.map((sys, i) => (
        <div class="system-card">
          <div class="card-header">
            <span class="card-num">0{i + 1}</span>
            <div>
              <h2 class="card-name">{sys.name}</h2>
              <p class="card-tagline">{sys.tagline}</p>
            </div>
          </div>
          <div class="card-body">
            {sys.body.map(para => <p>{para}</p>)}
          </div>
          <div class="card-tools">
            {sys.tools.map(tool => <span class="tag">{tool}</span>)}
          </div>
        </div>
      ))}
    </div>

    <hr class="rule" />

    <div class="footer-note">
      <p>The health system has its own playbook: <a href="https://glucose-playbook.vercel.app/" target="_blank" rel="noopener noreferrer">glucose-playbook.vercel.app ↗</a></p>
    </div>

  </div>
</BaseLayout>

<style>
.systems-page {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 var(--gap);
}

.page-header {
  padding: var(--s7) 0 var(--s6);
}

.eyebrow {
  font-family: var(--mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--fg-3);
  margin-bottom: var(--s3);
}

.page-header h1 {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-bottom: var(--s2);
}

.lead {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--fg-2);
  max-width: 46ch;
}

.rule {
  border: none;
  border-top: 1px solid var(--border);
  margin: 0;
}

.systems-list {
  padding: var(--s2) 0;
}

.system-card {
  padding: var(--s6) 0;
  border-bottom: 1px solid var(--border);
}

.system-card:last-child { border-bottom: none; }

.card-header {
  display: flex;
  align-items: flex-start;
  gap: var(--s3);
  margin-bottom: var(--s4);
}

.card-num {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--fg-3);
  padding-top: 0.4rem;
  flex-shrink: 0;
}

.card-name {
  font-size: 1.25rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin-bottom: 0.3rem;
  color: var(--ink);
}

.card-tagline {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--fg-3);
  letter-spacing: 0.02em;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: var(--s2);
  margin-bottom: var(--s4);
  max-width: 58ch;
}

.card-body p {
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--fg-2);
}

.card-tools {
  display: flex;
  gap: var(--s1);
  flex-wrap: wrap;
}

.footer-note {
  padding: var(--s5) 0;
  font-size: 0.88rem;
  color: var(--fg-3);
}

.footer-note a {
  color: var(--ink);
  font-weight: 600;
}

.footer-note a:hover {
  opacity: 0.7;
}

@media (max-width: 640px) {
  .page-header { padding: var(--s5) 0 var(--s4); }
  .system-card { padding: var(--s5) 0; }
}
</style>
