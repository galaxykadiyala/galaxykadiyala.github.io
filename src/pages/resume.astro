---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume" description="Resume of Galaxy Kadiyala — Technical Program Manager with 14+ years in cloud, infrastructure, and platform engineering.">
  <section class="section">
    <div class="container">

      <div class="resume-header">
        <div>
          <h1>Galaxy Kadiyala</h1>
          <p class="resume-tagline">Technical Program Manager · Bengaluru, India · igalaxyk@gmail.com · in/galaxyk</p>
        </div>
        <div class="resume-header-actions">
          <a href="/contact" class="btn outline">Contact →</a>
        </div>
      </div>

      <div class="resume-body">

        <!-- Summary -->
        <div class="resume-section">
          <div class="resume-section-label">Summary</div>
          <div class="resume-section-content">
            <p>
              Technical Program Manager with 14+ years of experience delivering large-scale cloud, data infrastructure,
              and platform engineering programs across globally distributed teams. Proven track record driving execution
              across Kubernetes-native storage, hyperconverged infrastructure, CI/CD modernization, and large cross-functional
              initiatives. Deputed via Aziro Technologies to Pure Storage and Rubrik — leading AWS migration delivery at
              Pure Storage and driving UI test release execution at Rubrik. Focused on predictability, release readiness,
              execution visibility, and engineering efficiency.
            </p>
          </div>
        </div>

        <!-- Experience -->
        <div class="resume-section">
          <div class="resume-section-label">Experience</div>
          <div class="resume-section-content">

            <div class="resume-item">
              <div class="resume-item-header">
                <div>
                  <h3 class="resume-item-title">Technical Program Manager</h3>
                  <span class="resume-item-org">Aziro Technologies (deputed to Pure Storage & Rubrik)</span>
                </div>
                <span class="tag yellow">Oct 2024 – Present</span>
              </div>
              <ul class="resume-item-bullets">
                <li>Leading end-to-end migration of core platform services from on-prem to AWS, coordinating 7 engineering streams and 30+ globally distributed engineers.</li>
                <li>Defined program milestones, governance model, and dependency sequencing enabling phased migration without service disruption.</li>
                <li>Introduced phased CI/CD rollout improving deployment reliability and reducing release cycle time from 7 days to 24 hours.</li>
                <li>Built integrated dashboards using Jira, Jenkins, and AWS CloudWatch for real-time visibility into migration progress.</li>
                <li>Improved operational efficiency through automated monitoring workflows, saving 200+ engineering hours quarterly.</li>
                <li>Driving UI release readiness for Rubrik platform teams — coordinating test execution, managing risks, and preparing leadership-facing release updates.</li>
              </ul>
            </div>

            <div class="resume-item">
              <div class="resume-item-header">
                <div>
                  <h3 class="resume-item-title">Founder & Program Lead</h3>
                  <span class="resume-item-org">MicroPay (Independent Project)</span>
                </div>
                <span class="tag orange">Mar 2024 – Sep 2024</span>
              </div>
              <ul class="resume-item-bullets">
                <li>Designed and led development of a unified pay-per-use digital wallet using the Interledger protocol.</li>
                <li>Created MVP system architecture, dynamic pricing models, and onboarding workflows.</li>
                <li>Scoped program budget ($60K–$85K) and validated early prototype flows with test customer groups.</li>
              </ul>
            </div>

            <div class="resume-item">
              <div class="resume-item-header">
                <div>
                  <h3 class="resume-item-title">Engineering Manager / Technical Program Manager</h3>
                  <span class="resume-item-org">Nutanix</span>
                </div>
                <span class="tag green">Feb 2021 – Feb 2024</span>
              </div>
              <ul class="resume-item-bullets">
                <li>Directed cross-functional programs supporting Nutanix's enterprise-scale infrastructure platform, used by 10,000+ customers worldwide.</li>
                <li>Drove multi-year cross-functional initiatives to adopt phased CI/CD, improving platform reliability by 30%.</li>
                <li>Managed program execution including roadmap alignment, release governance, triage, RCA, and risk management.</li>
                <li>Automated operational workflows resulting in 500+ engineering hours saved annually.</li>
                <li>Developed leadership dashboards improving delivery predictability and release transparency.</li>
              </ul>
            </div>

            <div class="resume-item">
              <div class="resume-item-header">
                <div>
                  <h3 class="resume-item-title">Senior Member of Technical Staff</h3>
                  <span class="resume-item-org">Nutanix</span>
                </div>
                <span class="tag blue">Nov 2017 – Jan 2021</span>
              </div>
              <ul class="resume-item-bullets">
                <li>Led QA strategy for Lifecycle Management and Disaster Recovery components across AHV (KVM) and ESXi.</li>
                <li>Validated DR workflows including snapshot integrity, replication, and failover.</li>
                <li>Built nested cluster model reducing build cycle time from 4 hours to 30 minutes.</li>
              </ul>
            </div>

            <div class="resume-item">
              <div class="resume-item-header">
                <div>
                  <h3 class="resume-item-title">Technical Lead</h3>
                  <span class="resume-item-org">Terralogic</span>
                </div>
                <span class="tag red">Dec 2011 – Oct 2017</span>
              </div>
              <ul class="resume-item-bullets">
                <li>Managed QA for Nutanix and Cisco product lines, focusing on automation, reliability, and network protocol testing.</li>
                <li>Led test strategy and execution for system and regression testing across enterprise networking products.</li>
              </ul>
            </div>

          </div>
        </div>

        <!-- Skills -->
        <div class="resume-section">
          <div class="resume-section-label">Skills</div>
          <div class="resume-section-content">
            <div class="skills-grid">
              {[
                { group: 'Program Management', skills: ['Roadmapping', 'Stakeholder Management', 'Release Planning', 'Dependency Mapping', 'Program Governance', 'Metrics & Dashboards', 'OKRs Alignment'] },
                { group: 'Tools & Platforms', skills: ['Jira', 'Confluence', 'Git / GitHub', 'Jenkins', 'CI/CD Pipelines', 'Postman', 'Selenium', 'TestNG'] },
                { group: 'Cloud & Infrastructure', skills: ['Kubernetes', 'AWS', 'Linux', 'Grafana', 'Microservices Architecture', 'Hyperconverged Infrastructure'] },
                { group: 'Technical & AI', skills: ['Python', 'Bash', 'API Debugging', 'Software Testing', 'ChatGPT / Claude / Copilot', 'Notion AI'] },
              ].map(group => (
                <div class="skill-group">
                  <h4 class="skill-group-title">{group.group}</h4>
                  <ul class="skill-list">
                    {group.skills.map(s => <li>{s}</li>)}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Patents -->
        <div class="resume-section">
          <div class="resume-section-label">Patents</div>
          <div class="resume-section-content">
            <div class="community-list">
              <div class="community-item">
                <div>
                  <strong>Managing HA File Servers</strong>
                  <span class="community-location">US 11,770,447 B2 · 2023</span>
                </div>
                <span class="tag green">Granted</span>
              </div>
              <div class="community-item">
                <div>
                  <strong>Verifying Snapshot Integrity</strong>
                  <span class="community-location">US 11,455,277 B2 · 2022</span>
                </div>
                <span class="tag green">Granted</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Certifications -->
        <div class="resume-section">
          <div class="resume-section-label">Certifications</div>
          <div class="resume-section-content">
            <div class="community-list">
              <div class="community-item">
                <div>
                  <strong>Certified SAFe® 6 Agilist</strong>
                  <span class="community-location">Scaled Agile, Inc. · 2025</span>
                </div>
                <span class="tag blue">Active</span>
              </div>
              <div class="community-item">
                <div>
                  <strong>Nutanix Certified Professional – Multicloud Infrastructure (NCP-MCI)</strong>
                  <span class="community-location">Nutanix · 2022</span>
                </div>
                <span class="tag blue">Active</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Education -->
        <div class="resume-section">
          <div class="resume-section-label">Education</div>
          <div class="resume-section-content">
            <div class="community-list">
              <div class="community-item">
                <div>
                  <strong>PGCP, Strategic Product Management</strong>
                  <span class="community-location">Indian Institute of Management, Visakhapatnam · 2025</span>
                </div>
                <span class="tag yellow">IIM</span>
              </div>
              <div class="community-item">
                <div>
                  <strong>M.Tech, Networking & Telecommunications</strong>
                  <span class="community-location">IIIT Pune · 2011</span>
                </div>
              </div>
              <div class="community-item">
                <div>
                  <strong>B.Tech, Information Technology</strong>
                  <span class="community-location">JNTU Hyderabad · 2009</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Volunteer -->
        <div class="resume-section">
          <div class="resume-section-label">Volunteer</div>
          <div class="resume-section-content">
            <div class="resume-item">
              <div class="resume-item-header">
                <div>
                  <h3 class="resume-item-title">Community Liaison</h3>
                  <span class="resume-item-org">Mozilla Foundation</span>
                </div>
                <span class="tag orange">Jun 2010 – Present</span>
              </div>
              <ul class="resume-item-bullets">
                <li>Led Mozilla's Firefox Student Ambassador program in India, promoting open web standards and digital literacy across student communities.</li>
                <li>Spearheaded outreach and contributor campaigns that engaged 10,000+ students and early tech adopters across Asia.</li>
                <li>Represented Mozilla at national and international conferences, mentored new contributors, and scaled regional Mozilla community chapters.</li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
.resume-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid var(--ink);
}
.resume-header h1 { margin-bottom: 0.4rem; }
.resume-tagline {
  font-family: var(--mono);
  font-size: 0.8rem;
  opacity: 0.5;
}
.resume-header-actions { display: flex; gap: 0.75rem; flex-shrink: 0; }

.resume-body { display: flex; flex-direction: column; }

.resume-section {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 3rem;
  padding: 2.5rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.resume-section-label {
  font-family: var(--mono);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0.4;
  padding-top: 0.25rem;
  position: sticky;
  top: 80px;
  align-self: start;
}

.resume-section-content p {
  font-size: 1.02rem;
  opacity: 0.75;
  max-width: 68ch;
  line-height: 1.75;
}

.resume-item { margin-bottom: 2.5rem; }
.resume-item:last-child { margin-bottom: 0; }

.resume-item-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 0.85rem;
  flex-wrap: wrap;
}

.resume-item-title {
  font-size: 1.05rem;
  font-weight: 700;
  margin-bottom: 0.2rem;
}

.resume-item-org {
  font-family: var(--mono);
  font-size: 0.78rem;
  opacity: 0.45;
}

.resume-item-bullets {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}
.resume-item-bullets li {
  font-family: var(--sans);
  font-size: 0.93rem;
  font-weight: 400;
  opacity: 0.7;
  padding-left: 1.2rem;
  position: relative;
  line-height: 1.6;
}
.resume-item-bullets li::before {
  content: '→';
  position: absolute;
  left: 0;
  font-size: 0.8rem;
  opacity: 0.4;
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
}

.skill-group-title {
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.75rem;
  opacity: 0.5;
}

.skill-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.skill-list li {
  font-family: var(--sans);
  font-size: 0.92rem;
  font-weight: 400;
  opacity: 0.72;
}

.community-list { display: flex; flex-direction: column; }

.community-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.9rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  flex-wrap: wrap;
}
.community-item strong {
  font-family: var(--sans);
  font-size: 0.95rem;
  font-weight: 700;
  display: block;
  margin-bottom: 0.2rem;
}
.community-location {
  font-family: var(--mono);
  font-size: 0.72rem;
  opacity: 0.4;
}

@media (max-width: 768px) {
  .resume-section { grid-template-columns: 1fr; gap: 1rem; }
  .resume-header { flex-direction: column; align-items: flex-start; }
  .skills-grid { grid-template-columns: 1fr; }
  .resume-item-header { flex-direction: column; }
}
</style>
