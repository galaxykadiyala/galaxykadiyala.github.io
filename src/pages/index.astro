---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title="Galaxy Kadiyala — TPM · Systems · AI"
  description="Technical Program Manager focused on systems thinking, AI workflows, and building leverage. Based in Bengaluru."
>
  <div class="home">

    <section class="hero">
      <p class="eyebrow">Technical Program Manager &middot; AI &middot; Systems</p>
      <h1>Systems &gt; effort.<br/>I build leverage.</h1>
      <p class="lead">15+ years across Nutanix, Pure Storage, and Rubrik. 2 US patents in distributed systems. AI is a tool. Systems do the work.</p>
      <div class="hero-cta">
        <a href="/projects" class="btn">Selected Work</a>
        <a href="/blog" class="btn outline">Writing</a>
      </div>
    </section>

    <hr class="rule" />

    <section class="section">
      <p class="section-label">Selected Work</p>
      <div class="work-grid">
        {featuredProjects.map((project, i) => (
          <div class="work-item">
            <span class="work-num">{String(i + 1).padStart(2, '0')}</span>
            <div class="work-body">
              <h3 class="work-title">
                <a href={`/projects/${project.slug}`}>{project.data.title}</a>
              </h3>
              <p class="work-desc">{project.data.summary}</p>
              {project.data.blogPostSlug && (
                <a href={`/blog/${project.data.blogPostSlug}`} class="work-link">
                  Read case study →
                </a>
              )}
              {!project.data.blogPostSlug && project.data.externalUrl && (
                <a href={project.data.externalUrl} target="_blank" rel="noopener" class="work-link">
                  Visit live ↗
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
      <a href="/projects" class="all-link">View all work →</a>
    </section>


    <hr class="rule" />

    <section class="section">
      <p class="section-label">Recent Writing</p>
      <div class="posts-list">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-row">
            <span class="post-date">{fmtDate(post.data.date)}</span>
            <span class="post-title">{post.data.title}</span>
          </a>
        ))}
      </div>
      <a href="/blog" class="all-link">All writing →</a>
    </section>
    <p class="availability">Currently open to full-time TPM roles. Bengaluru-based, open to remote. <a href="/contact">Get in touch →</a></p>

  </div>
</BaseLayout>

<style>
.home {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 var(--gap);
}

/* ── Hero ─────────────────────────────────────── */
.hero {
  padding: 5rem 0 4.5rem;
}

.eyebrow {
  font-family: var(--mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink);
  opacity: 0.45;
  margin-bottom: 1.75rem;
}

.hero h1 {
  font-size: clamp(2.6rem, 6.5vw, 4.4rem);
  font-weight: 800;
  line-height: 1.06;
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
  color: var(--ink);
}

.lead {
  font-size: 1rem;
  line-height: 1.75;
  opacity: 0.6;
  max-width: 52ch;
  margin-bottom: 2.5rem;
}

.hero-cta {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.availability {
  padding: 0 0 3.5rem;
  margin-top: 1rem;
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  opacity: 0.45;
}

.availability a {
  color: inherit;
  text-decoration: none;
}

.availability a:hover {
  opacity: 1;
}

/* ── Divider ──────────────────────────────────── */
.rule {
  border: none;
  border-top: 1px solid rgba(10, 10, 10, 0.12);
  margin: 0;
}

/* ── Sections ─────────────────────────────────── */
.section {
  padding: 3.5rem 0;
}

.section-label {
  font-family: var(--mono);
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  opacity: 0.4;
  margin-bottom: 2rem;
}

/* ── Work ─────────────────────────────────────── */
.work-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 3rem;
  margin-bottom: 1.5rem;
}

.work-item {
  display: grid;
  grid-template-columns: 3rem 1fr;
  gap: 1rem;
  align-items: start;
  padding: 1.75rem 0;
  border-bottom: 1px solid rgba(10, 10, 10, 0.1);
}

.work-item:nth-child(-n+2) {
  border-top: 1px solid rgba(10, 10, 10, 0.1);
}

.work-num {
  font-family: var(--mono);
  font-size: 1.5rem;
  font-weight: 700;
  opacity: 0.18;
  line-height: 1.3;
  padding-top: 0.1rem;
}

.work-title {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  margin-bottom: 0.4rem;
}

.work-title a {
  color: var(--ink);
  text-decoration: none;
  transition: opacity 0.15s;
}

.work-title a:hover {
  opacity: 0.65;
}

.work-desc {
  font-size: 0.88rem;
  line-height: 1.65;
  opacity: 0.6;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 0.65rem;
}

.work-link {
  font-family: var(--mono);
  font-size: 0.72rem;
  opacity: 0.4;
  color: var(--ink);
  text-decoration: none;
  letter-spacing: 0.02em;
  transition: opacity 0.15s;
}

.work-link:hover { opacity: 0.9; }

/* ── Posts ────────────────────────────────────── */
.posts-list {
  margin-bottom: 1.5rem;
}

.post-row {
  display: grid;
  grid-template-columns: 110px 1fr;
  gap: 1.5rem;
  align-items: baseline;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(10, 10, 10, 0.1);
  text-decoration: none;
  color: var(--ink);
  transition: opacity 0.15s;
}

.post-row:first-child {
  border-top: 1px solid rgba(10, 10, 10, 0.1);
}

.post-row:hover {
  opacity: 0.6;
}

.post-date {
  font-family: var(--mono);
  font-size: 0.72rem;
  opacity: 0.4;
  white-space: nowrap;
}

.post-title {
  font-size: 0.95rem;
  font-weight: 600;
  line-height: 1.4;
}

/* ── Utility ──────────────────────────────────── */
.all-link {
  font-family: var(--mono);
  font-size: 0.78rem;
  letter-spacing: 0.04em;
  opacity: 0.5;
  text-decoration: none;
  transition: opacity 0.15s;
}

.all-link:hover {
  opacity: 1;
}

/* ── Mobile ───────────────────────────────────── */
@media (max-width: 640px) {
  .hero {
    padding: 3rem 0 3rem;
  }

  .br-desktop {
    display: none;
  }

  .work-grid {
    grid-template-columns: 1fr;
  }

  .work-item:nth-child(2) {
    border-top: none;
  }

  .post-row {
    grid-template-columns: 1fr;
    gap: 0.2rem;
  }

  .post-date {
    font-size: 0.68rem;
  }

}
</style>
