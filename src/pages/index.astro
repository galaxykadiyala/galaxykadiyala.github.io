---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title="Galaxy Kadiyala — TPM · Systems · AI"
  description="Technical Program Manager focused on systems thinking, AI workflows, and building leverage. Based in Bengaluru."
>
  <div class="home">

    <section class="hero">
      <p class="eyebrow">Technical Program Manager &middot; AI &middot; Systems</p>
      <h1>Systems &gt; effort.<br/>I build leverage.</h1>
      <p class="lead">I design systems for execution, decision-making, and leverage.<br class="br-desktop"/>AI is a tool. Systems do the work.</p>
      <div class="hero-cta">
        <a href="/projects" class="btn">Selected Work</a>
        <a href="/blog" class="btn outline">Writing</a>
      </div>
    </section>

    <hr class="rule" />

    <section class="section">
      <p class="section-label">Selected Work</p>
      <div class="work-list">
        <a href="https://glucose-playbook.vercel.app/" class="work-item" target="_blank" rel="noopener noreferrer">
          <span class="work-num">01</span>
          <div class="work-body">
            <h3 class="work-title">Glucose Optimization System</h3>
            <p class="work-desc">CGM-driven system for real-time decision-making. Daily feedback loops for food, movement, and energy.</p>
          </div>
          <span class="work-url">glucose-playbook.vercel.app ↗</span>
        </a>
        <a href="https://smartsprouts-ai.vercel.app/" class="work-item" target="_blank" rel="noopener noreferrer">
          <span class="work-num">02</span>
          <div class="work-body">
            <h3 class="work-title">AI-Built Learning Platform</h3>
            <p class="work-desc">Built using AI tools from zero to deployment in days. Speed, iteration, and practical usage — not prototypes.</p>
          </div>
          <span class="work-url">smartsprouts-ai.vercel.app ↗</span>
        </a>
      </div>
      <a href="/projects" class="all-link">View all work →</a>
    </section>

    <hr class="rule" />

    <section class="section">
      <p class="section-label">Systems I Operate</p>
      <div class="systems-table">
        <div class="sys-row">
          <p class="sys-name">Execution</p>
          <p class="sys-desc">Notes → Tasks → Feedback loops. Everything captured, prioritized, and reviewed. Nothing lives only in my head.</p>
        </div>
        <div class="sys-row">
          <p class="sys-name">AI Workflows</p>
          <p class="sys-desc">LLM-assisted drafting, code review, and automation at every layer. The goal is leverage, not automation.</p>
        </div>
        <div class="sys-row">
          <p class="sys-name">Health Data</p>
          <p class="sys-desc">CGM + sleep + movement → daily decisions. Body treated as an optimizable system with real feedback loops.</p>
        </div>
      </div>
      <a href="/systems" class="all-link">See how this works →</a>
    </section>

    <hr class="rule" />

    <section class="section">
      <p class="section-label">Recent Writing</p>
      <div class="posts-list">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-row">
            <span class="post-date">{fmtDate(post.data.date)}</span>
            <span class="post-title">{post.data.title}</span>
          </a>
        ))}
      </div>
      <a href="/blog" class="all-link">All writing →</a>
    </section>

  </div>
</BaseLayout>

<style>
.home {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 var(--gap);
}

/* ── Hero ─────────────────────────────────────── */
.hero {
  padding: 5rem 0 4.5rem;
}

.eyebrow {
  font-family: var(--mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink);
  opacity: 0.45;
  margin-bottom: 1.75rem;
}

.hero h1 {
  font-size: clamp(2.6rem, 6.5vw, 4.4rem);
  font-weight: 800;
  line-height: 1.06;
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
  color: var(--ink);
}

.lead {
  font-size: 1rem;
  line-height: 1.75;
  opacity: 0.6;
  max-width: 52ch;
  margin-bottom: 2.5rem;
}

.hero-cta {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

/* ── Divider ──────────────────────────────────── */
.rule {
  border: none;
  border-top: 1px solid rgba(10, 10, 10, 0.12);
  margin: 0;
}

/* ── Sections ─────────────────────────────────── */
.section {
  padding: 3.5rem 0;
}

.section-label {
  font-family: var(--mono);
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  opacity: 0.4;
  margin-bottom: 2rem;
}

/* ── Work ─────────────────────────────────────── */
.work-list {
  margin-bottom: 1.5rem;
}

.work-item {
  display: grid;
  grid-template-columns: 2.5ch 1fr auto;
  gap: 1.5rem;
  align-items: start;
  padding: 1.75rem 0;
  border-bottom: 1px solid rgba(10, 10, 10, 0.1);
  text-decoration: none;
  color: var(--ink);
  transition: opacity 0.15s;
}

.work-item:first-child {
  border-top: 1px solid rgba(10, 10, 10, 0.1);
}

.work-item:hover {
  opacity: 0.65;
}

.work-num {
  font-family: var(--mono);
  font-size: 0.78rem;
  opacity: 0.3;
  padding-top: 0.15rem;
}

.work-title {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.4rem;
  letter-spacing: -0.01em;
}

.work-desc {
  font-size: 0.88rem;
  line-height: 1.65;
  opacity: 0.6;
}

.work-url {
  font-family: var(--mono);
  font-size: 0.68rem;
  opacity: 0.35;
  white-space: nowrap;
  padding-top: 0.2rem;
  transition: opacity 0.15s;
}

.work-item:hover .work-url {
  opacity: 0.7;
}

/* ── Systems ──────────────────────────────────── */
.systems-table {
  margin-bottom: 1.5rem;
}

.sys-row {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 2rem;
  padding: 1.25rem 0;
  border-bottom: 1px solid rgba(10, 10, 10, 0.1);
}

.sys-row:first-child {
  border-top: 1px solid rgba(10, 10, 10, 0.1);
}

.sys-name {
  font-weight: 700;
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding-top: 0.1rem;
}

.sys-desc {
  font-size: 0.88rem;
  line-height: 1.7;
  opacity: 0.65;
}

/* ── Section sub ──────────────────────────────── */
.section-sub {
  font-size: 0.85rem;
  opacity: 0.45;
  margin-top: -1.25rem;
  margin-bottom: 2rem;
  font-family: var(--mono);
  letter-spacing: 0.02em;
}

/* ── Posts ────────────────────────────────────── */
.posts-list {
  margin-bottom: 1.5rem;
}

.post-row {
  display: grid;
  grid-template-columns: 110px 1fr;
  gap: 1.5rem;
  align-items: baseline;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(10, 10, 10, 0.1);
  text-decoration: none;
  color: var(--ink);
  transition: opacity 0.15s;
}

.post-row:first-child {
  border-top: 1px solid rgba(10, 10, 10, 0.1);
}

.post-row:hover {
  opacity: 0.6;
}

.post-date {
  font-family: var(--mono);
  font-size: 0.72rem;
  opacity: 0.4;
  white-space: nowrap;
}

.post-title {
  font-size: 0.95rem;
  font-weight: 600;
  line-height: 1.4;
}

/* ── Utility ──────────────────────────────────── */
.all-link {
  font-family: var(--mono);
  font-size: 0.78rem;
  letter-spacing: 0.04em;
  opacity: 0.5;
  text-decoration: none;
  transition: opacity 0.15s;
}

.all-link:hover {
  opacity: 1;
}

/* ── Mobile ───────────────────────────────────── */
@media (max-width: 640px) {
  .hero {
    padding: 3rem 0 3rem;
  }

  .br-desktop {
    display: none;
  }

  .work-item {
    grid-template-columns: 2.5ch 1fr;
    gap: 1rem;
  }

  .work-url {
    display: none;
  }

  .sys-row {
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }

  .sys-name {
    opacity: 0.5;
    font-size: 0.75rem;
  }

  .post-row {
    grid-template-columns: 1fr;
    gap: 0.2rem;
  }

  .post-date {
    font-size: 0.68rem;
  }
}
</style>
