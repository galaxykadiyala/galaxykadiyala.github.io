---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorldMap from '../components/WorldMap.astro';
---

<BaseLayout title="About" description="Galaxy Kadiyala — Technical Program Manager focused on systems, execution, and leverage. 15+ years across cloud, infrastructure, and platform engineering.">
  <section class="section" style="padding-bottom: 0">
    <div class="container">

      <div class="about-grid">

        <!-- Left: big statement -->
        <div class="about-left">
          <h1 class="about-title">
            TPM.<br/>
            Systems builder.<br/>
            <em>Open web</em> believer.
          </h1>
          <p class="about-tagline">Most work fails at execution. I fix that.</p>
          <div class="about-accent-block">
            <span class="tag red">Technical Program Manager</span>
            <span class="tag blue">Systems Thinking</span>
            <span class="tag green">AI &amp; Infra</span>
            <span class="tag orange">2&times; US Patents</span>
            <span class="tag">Mozilla</span>
          </div>
        </div>

        <!-- Right: bio -->
        <div class="about-right">
          <div class="about-bio">
            <p>
              I work on systems that need to deliver, not just exist.
            </p>
            <p>
              Over the last 15+ years, I've worked across cloud, infrastructure, QA, and platform engineering. I focus on execution across distributed teams and complex dependencies.
            </p>
            <p>
              My focus is simple. Turn messy execution into systems that scale.
            </p>
            <p>
              Outside work, I've been part of the Mozilla community since 2010. I mentor contributors and help scale open web initiatives across the world.
            </p>
            <p>
              That experience shaped how I think. Systems over effort. Leverage over activity.
            </p>
          </div>

          <div class="about-links">
            <a href="/projects" class="btn">View Work →</a>
            <a href="/contact" class="btn outline">Get in touch →</a>
            <a href="/resume" class="btn outline">Resume ↗</a>
          </div>
        </div>

      </div>

    </div>
  </section>

  <div class="container">
    <WorldMap />
  </div>

</BaseLayout>

<style>
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 0;
}

.about-title {
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 1.25rem;
}
.about-title em {
  font-family: var(--sans);
  font-style: normal;
  font-weight: 800;
  color: var(--accent-1);
}

.about-tagline {
  font-family: var(--mono);
  font-size: 0.82rem;
  color: var(--fg-2);
  margin-bottom: 1.75rem;
  letter-spacing: 0.01em;
}

.about-accent-block {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.about-bio {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}
.about-bio p {
  font-size: 1.05rem;
  opacity: 0.8;
  line-height: 1.75;
}

.about-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}


@media (max-width: 768px) {
  .about-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}
</style>
