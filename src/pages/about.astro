---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Galaxy Kadiyala — Mozilla community member, open source evangelist, Bangalore.">
  <section class="section">
    <div class="container">

      <div class="about-grid">

        <!-- Left: big statement -->
        <div class="about-left">
          <h1 class="about-title">
            TPM.<br/>
            Builder.<br/>
            <em>Open Web</em> believer.
          </h1>
          <div class="about-accent-block">
            <span class="tag red">Technical Program Manager</span>
            <span class="tag blue">2x US Patents</span>
            <span class="tag green">Cloud &amp; Infra</span>
            <span class="tag orange">Mozilla</span>
          </div>
        </div>

        <!-- Right: bio -->
        <div class="about-right">
          <div class="about-bio">
            <p>
              Hey, I'm Galaxy Kadiyala — a Technical Program Manager focused on making large-scale engineering systems actually deliver. I've spent 15+ years across cloud, infrastructure, QA, and platform engineering, driving AWS migrations, CI/CD transformations, UI testing, and release execution across distributed teams.
            </p>
            <p>
              At Nutanix, Pure Storage, and Rubrik, I've worked on systems used by 10,000+ customers — coordinating engineering streams, managing dependencies, and improving delivery predictability. I hold two US patents in distributed systems.
            </p>
            <p>
              Outside work, I've been part of the Mozilla community since 2010 — mentoring contributors and helping scale open web initiatives across India. That shaped how I think about collaboration, ownership, and building systems that scale beyond individuals.
            </p>
          </div>

          <div class="about-links">
            <a href="https://github.com/galaxykadiyala" target="_blank" rel="noopener" class="btn">GitHub →</a>
            <a href="/contact" class="btn outline">Get in touch →</a>
            <a href="/resume" class="btn outline">Resume →</a>
          </div>
        </div>

      </div>

      <!-- Timeline -->
      <div class="timeline-section">
        <h2 class="timeline-heading">Timeline</h2>
        <div class="timeline">
          {[
            { year: '2010', label: 'Joined Mozilla community — Firefox evangelist', color: 'var(--accent-3)' },
            { year: '2011', label: 'M.Tech at IIIT Pune · Technical Lead at Terralogic', color: 'var(--accent-4)' },
            { year: '2013', label: 'Attended MozFest in London', color: 'var(--accent-2)' },
            { year: '2015', label: 'Mozilla Reps Mentor · FSA Bootcamp India', color: 'var(--accent-5)' },
            { year: '2017', label: 'Joined Nutanix as Senior Member of Technical Staff', color: 'var(--accent-1)' },
            { year: '2021', label: 'Engineering Manager / TPM at Nutanix', color: 'var(--accent-3)' },
            { year: '2022', label: 'US Patent — Verifying Snapshot Integrity', color: 'var(--accent-4)' },
            { year: '2023', label: 'US Patent — Managing HA File Servers', color: 'var(--accent-2)' },
            { year: '2024', label: 'TPM at Aziro — deputed to Pure Storage & Rubrik', color: 'var(--accent-5)' },
            { year: 'Now', label: 'IIM PGCP grad · Reviving the blog. Still building.', color: 'var(--accent-1)' },
          ].map(item => (
            <div class="timeline-item">
              <div class="timeline-dot" style={`background: ${item.color}`}></div>
              <div class="timeline-year">{item.year}</div>
              <div class="timeline-label">{item.label}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
  padding-bottom: 5rem;
  border-bottom: 2px solid var(--ink);
  margin-bottom: 5rem;
}

.about-title {
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 2rem;
}
.about-title em {
  font-family: var(--sans);
  font-style: normal;
  font-weight: 800;
  color: var(--accent-1);
}

.about-accent-block {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.about-bio {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}
.about-bio p {
  font-size: 1.1rem;
  opacity: 0.8;
}

.about-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

/* Timeline */
.timeline-heading {
  margin-bottom: 2.5rem;
  font-size: clamp(1.5rem, 3vw, 2.5rem);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  padding-left: 2rem;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 7px;
  top: 10px;
  bottom: 10px;
  width: 2px;
  background: var(--ink);
  opacity: 0.12;
}

.timeline-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 1rem;
  align-items: center;
  padding: 1.25rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  position: relative;
}

.timeline-dot {
  position: absolute;
  left: -2rem;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 2px solid var(--paper);
  outline: 2px solid var(--ink);
  top: 50%;
  transform: translateY(-50%);
}

.timeline-year {
  font-family: var(--mono);
  font-weight: 500;
  font-size: 0.85rem;
  opacity: 0.45;
}

.timeline-label {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 1rem;
}

@media (max-width: 768px) {
  .about-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}
</style>
