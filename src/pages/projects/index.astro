---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const statusColors: Record<string, string> = {
  active:   'green',
  shipped:  'blue',
  archived: 'red',
};

const categoryLabel: Record<string, string> = {
  professional: 'Professional',
  personal:     'Personal',
  community:    'Community',
};

const tagColorList = ['blue', 'orange', 'green', 'red', 'yellow'];
---

<BaseLayout title="Projects" description="Programs Galaxy Kadiyala has shipped, systems built, and communities been part of.">
  <section class="section">
    <div class="container">

      <div class="page-header">
        <div class="page-header-text">
          <h1>Projects</h1>
          <p>Programs I've shipped, systems I've built, and communities I've been part of.</p>
        </div>
        <a href="https://github.com/galaxykadiyala" target="_blank" rel="noopener" class="btn outline">
          GitHub →
        </a>
      </div>

      <div class="projects-grid">
        {projects.map((project, i) => (
          <div class="project-card">
            <div class="project-card-top">
              <div class="project-year">{project.data.year}</div>
              <div class="project-badges">
                <span class={`tag ${statusColors[project.data.status]}`}>
                  {project.data.status}
                </span>
                <span class="tag">{categoryLabel[project.data.category]}</span>
              </div>
            </div>

            <h2 class="project-title">
              <a href={`/projects/${project.slug}`} class="project-title-link">
                {project.data.title}
              </a>
            </h2>

            <p class="project-desc">{project.data.summary}</p>

            {project.data.techStack && (
              <div class="project-tags">
                {project.data.techStack.map((tag, j) => (
                  <span class={`tag ${tagColorList[(i + j) % tagColorList.length]}`}>{tag}</span>
                ))}
              </div>
            )}

            <div class="project-links">
              {project.data.externalUrl && (
                <a href={project.data.externalUrl} target="_blank" rel="noopener" class="secondary-link">
                  Visit live ↗
                </a>
              )}
              {project.data.blogPostSlug && (
                <a href={`/blog/${project.data.blogPostSlug}`} class="secondary-link">
                  Read case study →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid var(--ink);
}
.page-header h1 { margin-bottom: 0.4rem; }
.page-header p {
  font-family: var(--mono);
  font-size: 0.85rem;
  opacity: 0.5;
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.75rem;
}

.project-card {
  border: 2px solid var(--ink);
  border-radius: 10px;
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  background: var(--paper);
  transition: transform 0.15s, box-shadow 0.15s;
  position: relative;
  overflow: hidden;
}
.project-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 70%, rgba(0,0,0,0.03));
  pointer-events: none;
}
.project-card:hover {
  transform: translate(-4px, -4px);
  box-shadow: 6px 6px 0 var(--ink);
}

.project-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
}

.project-year {
  font-family: var(--mono);
  font-size: 0.75rem;
  font-weight: 500;
  opacity: 0.35;
  letter-spacing: 0.05em;
}

.project-badges {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.project-title {
  font-size: 1.4rem;
  line-height: 1.15;
  letter-spacing: -0.02em;
}

.project-title-link {
  color: inherit;
  text-decoration: none;
  transition: color 0.15s;
}
.project-title-link::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 8px;
}
.project-card:hover .project-title-link { color: var(--accent-1); }

.project-desc {
  font-size: 0.95rem;
  opacity: 0.65;
  line-height: 1.65;
  font-family: var(--serif);
  flex: 1;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.project-links {
  display: flex;
  gap: 1rem;
  margin-top: auto;
  flex-wrap: wrap;
}

.secondary-link {
  position: relative;
  z-index: 1;
  font-family: var(--mono);
  font-size: 0.75rem;
  opacity: 0.5;
  text-decoration: none;
  transition: opacity 0.15s;
  letter-spacing: 0.02em;
}
.secondary-link:hover { opacity: 1; }

@media (max-width: 640px) {
  .page-header { flex-direction: column; align-items: flex-start; }
}
</style>
