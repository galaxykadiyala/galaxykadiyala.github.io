---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);

const statusColors: Record<string, string> = {
  active: 'green',
  archived: 'red',
  wip: 'yellow',
};

const tagColorList = ['blue', 'orange', 'green', 'red', 'yellow'];
---

<BaseLayout title="Projects" description="Things Galaxy Kadiyala has built and worked on.">
  <section class="section">
    <div class="container">

      <div class="page-header">
        <div class="page-header-text">
          <h1>Projects</h1>
          <p>Things I've built, contributed to, or been obsessed with.</p>
        </div>
        <a href="https://github.com/galaxykadiyala" target="_blank" rel="noopener" class="btn outline">
          GitHub →
        </a>
      </div>

      <div class="projects-grid">
        {projects.map((project, i) => (
          <div class="project-card">
            <div class="project-card-top">
              <div class="project-year">{project.data.year}</div>
              <span class={`tag ${statusColors[project.data.status ?? 'active']}`}>
                {project.data.status ?? 'active'}
              </span>
            </div>

            <h2 class="project-title">{project.data.title}</h2>
            <p class="project-desc">{project.data.description}</p>

            {project.data.tags && (
              <div class="project-tags">
                {project.data.tags.map((tag, j) => (
                  <span class={`tag ${tagColorList[(i + j) % tagColorList.length]}`}>{tag}</span>
                ))}
              </div>
            )}

            <div class="project-links">
              {project.data.url && (
                <a href={project.data.url} target="_blank" rel="noopener" class="btn">
                  Visit →
                </a>
              )}
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener" class="btn outline">
                  GitHub →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid var(--ink);
}
.page-header h1 { margin-bottom: 0.4rem; }
.page-header p {
  font-family: var(--mono);
  font-size: 0.85rem;
  opacity: 0.5;
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.75rem;
}

.project-card {
  border: 2px solid var(--ink);
  border-radius: 10px;
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  background: var(--paper);
  transition: transform 0.15s, box-shadow 0.15s;
  position: relative;
  overflow: hidden;
}
.project-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 70%, rgba(0,0,0,0.03));
  pointer-events: none;
}
.project-card:hover {
  transform: translate(-4px, -4px);
  box-shadow: 6px 6px 0 var(--ink);
}

.project-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.project-year {
  font-family: var(--mono);
  font-size: 0.75rem;
  font-weight: 500;
  opacity: 0.35;
  letter-spacing: 0.05em;
}

.project-title {
  font-size: 1.4rem;
  line-height: 1.15;
  letter-spacing: -0.02em;
}

.project-desc {
  font-size: 0.95rem;
  opacity: 0.65;
  line-height: 1.65;
  font-family: var(--serif);
  flex: 1;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.project-links {
  display: flex;
  gap: 0.75rem;
  margin-top: auto;
}
.project-links .btn {
  font-size: 0.82rem;
  padding: 0.55rem 1rem;
}

@media (max-width: 640px) {
  .page-header { flex-direction: column; align-items: flex-start; }
}
</style>
