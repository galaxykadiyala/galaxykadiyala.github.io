---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const categoryLabel: Record<string, string> = {
  professional: 'Professional',
  personal:     'Personal',
  community:    'Community',
};
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <article class="project-article">
    <div class="container">

      <header class="project-header">
        <div class="project-meta">
          <span class="tag coral">{project.data.status}</span>
          <span class="tag">{categoryLabel[project.data.category]}</span>
          <time class="project-year">{project.data.year}</time>
        </div>
        <h1 class="project-title">{project.data.title}</h1>
        <p class="project-summary">{project.data.summary}</p>
        {project.data.techStack && (
          <div class="project-stack">
            {project.data.techStack.map(tag => (
              <span class="tag coral">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="project-content">
        <Content />
      </div>

      {(project.data.blogPostSlug || project.data.externalUrl) && (
        <div class="project-actions">
          {project.data.blogPostSlug && (
            <a href={`/blog/${project.data.blogPostSlug}`} class="btn">
              Read the full case study →
            </a>
          )}
          {project.data.externalUrl && (
            <a href={project.data.externalUrl} target="_blank" rel="noopener" class="btn outline">
              Visit the live site ↗
            </a>
          )}
        </div>
      )}

      <footer class="project-footer">
        <a href="/projects" class="btn outline">← All projects</a>
      </footer>

    </div>
  </article>
</BaseLayout>

<style>
.project-article {
  padding: clamp(2rem, 6vw, 5rem) 0;
}

.project-header {
  max-width: 760px;
  margin: 0 auto 3rem;
  text-align: center;
}

.project-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.project-year {
  font-family: var(--mono);
  font-size: 0.8rem;
  opacity: 0.5;
}

.project-title {
  font-size: clamp(2rem, 5vw, 3.5rem);
  line-height: 1.05;
  margin-bottom: 1rem;
  letter-spacing: -0.03em;
}

.project-summary {
  font-size: 1.15rem;
  opacity: 0.6;
  max-width: 55ch;
  margin: 0 auto 1.5rem;
  line-height: 1.7;
}

.project-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  justify-content: center;
}

.project-content {
  max-width: 720px;
  margin: 0 auto;
}

/* Prose styles — mirrors blog post */
.project-content :global(h2) { margin: 2.5rem 0 1rem; }
.project-content :global(h3) { margin: 2rem 0 0.75rem; }
.project-content :global(p)  { margin-bottom: 1.5rem; }
.project-content :global(a)  { color: var(--accent-4); text-decoration: underline; }
.project-content :global(ul),
.project-content :global(ol) { margin: 1.5rem 0; padding-left: 1.5rem; }
.project-content :global(li) {
  font-family: var(--serif);
  font-size: 1.1rem;
  line-height: 1.75;
  margin-bottom: 0.5rem;
}
.project-content :global(blockquote) {
  border-left: 4px solid var(--accent-1);
  margin: 2rem 0;
  padding: 1rem 1.5rem;
  background: var(--paper-2);
  border-radius: 0 8px 8px 0;
}
.project-content :global(code) {
  font-family: var(--mono);
  font-size: 0.85em;
  background: var(--paper-2);
  padding: 0.2em 0.4em;
  border-radius: 3px;
}
.project-content :global(hr) {
  border: none;
  border-top: 2px solid var(--ink);
  opacity: 0.12;
  margin: 3rem 0;
}

.project-actions {
  max-width: 720px;
  margin: 3rem auto 0;
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.project-footer {
  max-width: 720px;
  margin: 3rem auto 0;
  padding-top: 2rem;
  border-top: 1px solid rgba(0,0,0,0.1);
}
</style>
