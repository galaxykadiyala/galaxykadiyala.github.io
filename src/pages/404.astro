---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <section class="not-found">
    <div class="container">
      <div class="nf-number">404</div>
      <h1 class="nf-title">Page not found.</h1>
      <p class="nf-desc">That URL doesn't exist. Maybe it moved, maybe it never existed. The open web is a big place.</p>
      <div class="nf-actions">
        <a href="/" class="btn">Go Home →</a>
        <a href="/blog" class="btn outline">Read the Blog →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.not-found {
  display: flex;
  align-items: center;
  min-height: 70vh;
  padding: 4rem 0;
}
.nf-number {
  font-family: var(--sans);
  font-weight: 800;
  font-size: clamp(8rem, 20vw, 16rem);
  line-height: 1;
  letter-spacing: -0.05em;
  color: var(--accent-1);
  opacity: 0.15;
  margin-bottom: -1rem;
}
.nf-title {
  font-size: clamp(2rem, 5vw, 4rem);
  margin-bottom: 1rem;
}
.nf-desc {
  font-size: 1.15rem;
  opacity: 0.6;
  max-width: 45ch;
  margin-bottom: 2.5rem;
}
.nf-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
</style>
