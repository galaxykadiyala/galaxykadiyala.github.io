---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Galaxy Kadiyala.">
  <section class="section">
    <div class="container">

      <div class="contact-grid">

        <div class="contact-left">
          <h1 class="contact-title">
            Let's<br/>
            <em>talk.</em>
          </h1>
          <p class="contact-desc">
            Whether it's about Mozilla, open source, the web, or just something
            cool you're building — I'm always happy to connect.
          </p>

          <div class="contact-channels">
            <div class="channel">
              <span class="channel-label">Email</span>
              <a href="mailto:hello@galaxykadiyala.com" class="channel-value">
                hello@galaxykadiyala.com
              </a>
            </div>
            <div class="channel">
              <span class="channel-label">GitHub</span>
              <a href="https://github.com/galaxykadiyala" target="_blank" rel="noopener" class="channel-value">
                @galaxykadiyala
              </a>
            </div>
            <div class="channel">
              <span class="channel-label">Location</span>
              <span class="channel-value">Bangalore, India</span>
            </div>
          </div>
        </div>

        <div class="contact-right">
          <form class="contact-form" name="contact" netlify>
            <div class="form-group">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" placeholder="Ada Lovelace" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="ada@example.com" required />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="6" placeholder="What's on your mind?" required></textarea>
            </div>
            <button type="submit" class="btn">Send Message →</button>
          </form>
          <p class="form-note">
            ⚡ Or just email directly — I check it regularly.
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: start;
}

.contact-title {
  font-size: clamp(3.5rem, 8vw, 7rem);
  line-height: 0.95;
  letter-spacing: -0.04em;
  margin-bottom: 1.75rem;
}
.contact-title em {
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent-1);
}

.contact-desc {
  font-size: 1.1rem;
  opacity: 0.7;
  max-width: 40ch;
  margin-bottom: 3rem;
}

.contact-channels {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.channel {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.channel-label {
  font-family: var(--mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0.4;
}

.channel-value {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 1.05rem;
  transition: color 0.15s;
}
a.channel-value:hover { color: var(--accent-4); }

/* Form */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.form-group label {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  opacity: 0.6;
}

.form-group input,
.form-group textarea {
  font-family: var(--serif);
  font-size: 1rem;
  padding: 0.85rem 1rem;
  border: 2px solid var(--ink);
  border-radius: var(--radius);
  background: var(--paper);
  color: var(--ink);
  width: 100%;
  transition: border-color 0.15s, box-shadow 0.15s;
  resize: vertical;
}
.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--accent-4);
  box-shadow: 0 0 0 3px rgba(61, 90, 255, 0.12);
}
.form-group input::placeholder,
.form-group textarea::placeholder {
  opacity: 0.35;
}

.form-note {
  font-family: var(--mono);
  font-size: 0.78rem;
  opacity: 0.4;
  margin-top: 1rem;
}

@media (max-width: 768px) {
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}
</style>
