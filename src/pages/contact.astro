---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Galaxy Kadiyala.">
  <section class="section">
    <div class="container">

      <div class="contact-grid">

        <div class="contact-left">
          <h1 class="contact-title">
            Let's<br/>
            <em>talk.</em>
          </h1>
          <p class="contact-desc">
            Whether it's about Mozilla, open source, the web, or just something
            cool you're building — I'm always happy to connect.
          </p>

          <div class="contact-channels">
            <div class="channel">
              <span class="channel-label">Email</span>
              <a href="mailto:igalaxyk@gmail.com" class="channel-value">
                igalaxyk@gmail.com
              </a>
            </div>
            <div class="channel">
              <span class="channel-label">GitHub</span>
              <a href="https://github.com/galaxykadiyala" target="_blank" rel="noopener" class="channel-value">
                @galaxykadiyala
              </a>
            </div>
            <div class="channel">
              <span class="channel-label">Location</span>
              <span class="channel-value">🌏 Earth</span>
            </div>
          </div>
        </div>

        <div class="contact-right">
          <div class="form-cta">
            <p class="form-cta-desc">
              Fill out the form and it lands straight in my inbox.
              Takes less than a minute.
            </p>
            <a
              href="https://docs.google.com/forms/d/e/1FAIpQLSdQLkovA_XEooUqBxu5Ki4a_51eilAMO2eq3Ojd2kc-oFplww/viewform"
              target="_blank"
              rel="noopener"
              class="btn form-btn"
            >
              Open Contact Form →
            </a>
            <p class="form-note">Opens in a new tab · Responses go to my email</p>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: start;
}

.contact-title {
  font-size: clamp(3.5rem, 8vw, 7rem);
  line-height: 0.95;
  letter-spacing: -0.04em;
  margin-bottom: 1.75rem;
}
.contact-title em {
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent-1);
}

.contact-desc {
  font-size: 1.1rem;
  opacity: 0.7;
  max-width: 40ch;
  margin-bottom: 3rem;
}

.contact-channels {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.channel {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.channel-label {
  font-family: var(--mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0.4;
}

.channel-value {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 1.05rem;
  transition: color 0.15s;
}
a.channel-value:hover { color: var(--accent-4); }

/* Form */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.form-cta {
  border: 2px solid var(--ink);
  border-radius: 10px;
  padding: 2.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  background: var(--paper);
  box-shadow: 6px 6px 0 var(--accent-2);
}

.form-cta-desc {
  font-size: 1.1rem;
  opacity: 0.7;
  line-height: 1.65;
}

.form-btn {
  font-size: 1rem;
  padding: 1rem 2rem;
  align-self: flex-start;
}

.form-note {
  font-family: var(--mono);
  font-size: 0.75rem;
  opacity: 0.4;
}

@media (max-width: 768px) {
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}
</style>