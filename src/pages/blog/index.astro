---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const publishedPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const blogDateFormatter = new Intl.DateTimeFormat('en-US', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

---

<BaseLayout title="Blog" description="All posts by Galaxy Kadiyala">
  <section class="section">
    <div class="container">

      <div class="page-header">
        <h1>The Blog</h1>
        <p>{publishedPosts.length} posts since 2010 on program management, systems thinking, QA, 
and a long history of open-web community work.</p>
        <a href="/blog/tags" class="topics-link">Browse by topic →</a>
      </div>

      <div class="blog-list">
        {publishedPosts.map((post, i) => (
          <div class="blog-row">
            <div class="blog-row-meta">
              <time class="blog-row-date">
                {blogDateFormatter.format(post.data.date)}
              </time>
              <span class="tag coral">{post.data.category || 'Blog'}</span>
            </div>
            <div class="blog-row-content">
              <h2 class="blog-row-title">
                <a href={`/blog/${post.slug}`} class="blog-row-link">{post.data.title}</a>
              </h2>
              {post.data.description && <p class="blog-row-desc">{post.data.description}</p>}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="blog-row-tags">
                  {post.data.tags.map(tag => (
                    <a href={`/blog/tags/${tag}`} class="blog-row-tag">{tag}</a>
                  ))}
                </div>
              )}
            </div>
            <span class="blog-row-arrow">→</span>
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid var(--ink);
}
.page-header h1 {
  margin-bottom: 0.5rem;
}
.page-header p {
  font-family: var(--mono);
  font-size: 0.85rem;
  opacity: 0.5;
}
.topics-link {
  display: inline-block;
  margin-top: 0.75rem;
  font-family: var(--mono);
  font-size: 0.8rem;
  opacity: 0.45;
  transition: opacity 0.15s;
}
.topics-link:hover { opacity: 1; }

.blog-list {
  display: flex;
  flex-direction: column;
}

.blog-row {
  position: relative;
  display: grid;
  grid-template-columns: 200px 1fr 2rem;
  gap: 2rem;
  align-items: start;
  padding: 1.75rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
  transition: background 0.15s;
  border-radius: 4px;
  padding-inline: 0.5rem;
  cursor: pointer;
}
.blog-row:hover { background: var(--paper-2); }

.blog-row-meta {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding-top: 0.2rem;
}

.blog-row-date {
  font-family: var(--mono);
  font-size: 0.78rem;
  opacity: 0.45;
}

.blog-row-title {
  font-size: 1.2rem;
  line-height: 1.25;
  margin-bottom: 0.5rem;
}

.blog-row-link {
  color: inherit;
  text-decoration: none;
  transition: color 0.15s;
}
.blog-row-link::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 4px;
}
.blog-row:hover .blog-row-link { color: var(--accent-1); }

.blog-row-desc {
  font-size: 0.92rem;
  opacity: 0.6;
  font-family: var(--serif);
}

.blog-row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.6rem;
}

.blog-row-tag {
  position: relative;
  z-index: 1;
  font-family: var(--mono);
  font-size: 0.68rem;
  padding: 0.2em 0.6em;
  border-radius: 999px;
  background: rgba(216, 90, 48, 0.12);
  border: 1px solid rgba(216, 90, 48, 0.4);
  color: #d85a30;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}
.blog-row-tag:hover {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}
[data-theme="dark"] .blog-row-tag {
  background: rgba(255, 107, 74, 0.15);
  border-color: rgba(255, 107, 74, 0.4);
  color: #ff6b4a;
}

.blog-row-arrow {
  font-family: var(--sans);
  font-size: 1.2rem;
  opacity: 0.3;
  align-self: center;
  transition: all 0.15s;
}
.blog-row:hover .blog-row-arrow { opacity: 1; transform: translateX(4px); }

@media (max-width: 640px) {
  .blog-row {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
  }
  .blog-row-meta {
    flex-direction: row;
    align-items: center;
    grid-column: 1 / -1;
  }
  .blog-row-arrow { grid-row: 1; }
}
</style>
