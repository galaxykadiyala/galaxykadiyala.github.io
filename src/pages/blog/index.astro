---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const tagColors = ['red', 'yellow', 'green', 'blue', 'orange'];
---

<BaseLayout title="Blog" description="All posts by Galaxy Kadiyala">
  <section class="section">
    <div class="container">

      <div class="page-header">
        <h1>The Blog</h1>
        <p>{allPosts.length} posts since 2010 — mostly Mozilla, open source, and community.</p>
      </div>

      <div class="blog-list">
        {allPosts.map((post, i) => (
          <a href={`/blog/${post.slug}`} class="blog-row">
            <div class="blog-row-meta">
              <time class="blog-row-date">
                {post.data.date.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' })}
              </time>
              <span class={`tag ${tagColors[i % tagColors.length]}`}>{post.data.category || 'Blog'}</span>
            </div>
            <div class="blog-row-content">
              <h2 class="blog-row-title">{post.data.title}</h2>
              {post.data.description && <p class="blog-row-desc">{post.data.description}</p>}
            </div>
            <span class="blog-row-arrow">→</span>
          </a>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid var(--ink);
}
.page-header h1 {
  margin-bottom: 0.5rem;
}
.page-header p {
  font-family: var(--mono);
  font-size: 0.85rem;
  opacity: 0.5;
}

.blog-list {
  display: flex;
  flex-direction: column;
}

.blog-row {
  display: grid;
  grid-template-columns: 200px 1fr 2rem;
  gap: 2rem;
  align-items: start;
  padding: 1.75rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
  transition: background 0.15s;
  border-radius: 4px;
  padding-inline: 0.5rem;
}
.blog-row:hover { background: var(--paper-2); }

.blog-row-meta {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding-top: 0.2rem;
}

.blog-row-date {
  font-family: var(--mono);
  font-size: 0.78rem;
  opacity: 0.45;
}

.blog-row-title {
  font-size: 1.2rem;
  line-height: 1.25;
  margin-bottom: 0.5rem;
  transition: color 0.15s;
}
.blog-row:hover .blog-row-title { color: var(--accent-1); }

.blog-row-desc {
  font-size: 0.92rem;
  opacity: 0.6;
  font-family: var(--serif);
}

.blog-row-arrow {
  font-family: var(--sans);
  font-size: 1.2rem;
  opacity: 0.3;
  align-self: center;
  transition: all 0.15s;
}
.blog-row:hover .blog-row-arrow { opacity: 1; transform: translateX(4px); }

@media (max-width: 640px) {
  .blog-row {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
  }
  .blog-row-meta {
    flex-direction: row;
    align-items: center;
    grid-column: 1 / -1;
  }
  .blog-row-arrow { grid-row: 1; }
}
</style>
