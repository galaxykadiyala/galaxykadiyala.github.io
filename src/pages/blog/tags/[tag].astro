---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Set(allPosts.flatMap(p => p.data.tags ?? []));
  return [...tags].map(tag => ({
    params: { tag },
    props: {
      posts: allPosts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const blogDateFormatter = new Intl.DateTimeFormat('en-US', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

const tagColors = ['red', 'yellow', 'green', 'blue', 'orange'];
---

<BaseLayout title={tag} description={`Posts tagged "${tag}" — Galaxy Kadiyala`}>
  <section class="section">
    <div class="container">

      <a href="/blog/tags" class="back-link">← All topics</a>

      <div class="page-header">
        <h1>Tagged: {tag}</h1>
        <p>{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
      </div>

      <div class="blog-list">
        {posts.map((post, i) => (
          <div class="blog-row">
            <div class="blog-row-meta">
              <time class="blog-row-date">
                {blogDateFormatter.format(post.data.date)}
              </time>
              <span class={`tag ${tagColors[i % tagColors.length]}`}>{post.data.category || 'Blog'}</span>
            </div>
            <div class="blog-row-content">
              <h2 class="blog-row-title">
                <a href={`/blog/${post.slug}`} class="blog-row-link">{post.data.title}</a>
              </h2>
              {post.data.description && <p class="blog-row-desc">{post.data.description}</p>}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="blog-row-tags">
                  {post.data.tags.map(t => (
                    <a
                      href={`/blog/tags/${t}`}
                      class:list={['blog-row-tag', { active: t === tag }]}
                    >{t}</a>
                  ))}
                </div>
              )}
            </div>
            <span class="blog-row-arrow">→</span>
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.back-link {
  display: inline-block;
  font-family: var(--mono);
  font-size: 0.8rem;
  opacity: 0.5;
  margin-bottom: 2rem;
  transition: opacity 0.15s;
}
.back-link:hover { opacity: 1; }

.page-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid var(--ink);
}
.page-header h1 {
  margin-bottom: 0.5rem;
}
.page-header p {
  font-family: var(--mono);
  font-size: 0.85rem;
  opacity: 0.5;
}

.blog-list {
  display: flex;
  flex-direction: column;
}

.blog-row {
  position: relative;
  display: grid;
  grid-template-columns: 200px 1fr 2rem;
  gap: 2rem;
  align-items: start;
  padding: 1.75rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
  transition: background 0.15s;
  border-radius: 4px;
  padding-inline: 0.5rem;
  cursor: pointer;
}
.blog-row:hover { background: var(--paper-2); }

.blog-row-meta {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding-top: 0.2rem;
}

.blog-row-date {
  font-family: var(--mono);
  font-size: 0.78rem;
  opacity: 0.45;
}

.blog-row-title {
  font-size: 1.2rem;
  line-height: 1.25;
  margin-bottom: 0.5rem;
}

.blog-row-link {
  color: inherit;
  text-decoration: none;
  transition: color 0.15s;
}
.blog-row-link::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 4px;
}
.blog-row:hover .blog-row-link { color: var(--accent-1); }

.blog-row-desc {
  font-size: 0.92rem;
  opacity: 0.6;
  font-family: var(--serif);
}

.blog-row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.6rem;
}

.blog-row-tag {
  position: relative;
  z-index: 1;
  font-family: var(--mono);
  font-size: 0.68rem;
  padding: 0.2em 0.6em;
  border-radius: 999px;
  border: 1px solid rgba(0,0,0,0.12);
  color: var(--ink);
  opacity: 0.45;
  transition: opacity 0.15s, background 0.15s, border-color 0.15s, color 0.15s;
  text-decoration: none;
}
.blog-row-tag:hover,
.blog-row-tag.active {
  opacity: 1;
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}

.blog-row-arrow {
  font-family: var(--sans);
  font-size: 1.2rem;
  opacity: 0.3;
  align-self: center;
  transition: all 0.15s;
}
.blog-row:hover .blog-row-arrow { opacity: 1; transform: translateX(4px); }

@media (max-width: 640px) {
  .blog-row {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
  }
  .blog-row-meta {
    flex-direction: row;
    align-items: center;
    grid-column: 1 / -1;
  }
  .blog-row-arrow { grid-row: 1; }
}
</style>
