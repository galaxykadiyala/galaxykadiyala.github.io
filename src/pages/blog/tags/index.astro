---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);

function sizeClass(count: number): string {
  if (count >= 15) return 'xl';
  if (count >= 8) return 'lg';
  if (count >= 3) return 'md';
  return 'sm';
}
---

<BaseLayout title="Browse by topic" description="All tags across the blog — Galaxy Kadiyala">
  <section class="section">
    <div class="container">

      <a href="/blog" class="back-link">← All writing</a>

      <div class="page-header">
        <h1>Browse by topic</h1>
        <p>{tags.length} topics across {allPosts.length} posts</p>
      </div>

      <div class="tag-cloud">
        {tags.map(([tag, count], i) => (
          <a
            href={`/blog/tags/${tag}`}
            class={`tag-pill size-${sizeClass(count)}`}
          >
            {tag}<span class="tag-count">({count})</span>
          </a>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.back-link {
  display: inline-block;
  font-family: var(--mono);
  font-size: 0.8rem;
  opacity: 0.5;
  margin-bottom: 2rem;
  transition: opacity 0.15s;
}
.back-link:hover { opacity: 1; }

.page-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid var(--ink);
}
.page-header h1 {
  margin-bottom: 0.5rem;
}
.page-header p {
  font-family: var(--mono);
  font-size: 0.85rem;
  opacity: 0.5;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem 0.6rem;
  align-items: center;
  padding: 1rem 0;
}

.tag-pill {
  display: inline-flex;
  align-items: baseline;
  gap: 0.3em;
  font-family: var(--mono);
  font-weight: 600;
  line-height: 1;
  padding: 0.45em 0.85em;
  border-radius: 999px;
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
  text-decoration: none;
}

.tag-pill:hover {
  transform: scale(1.08) translateY(-3px);
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
  opacity: 1 !important;
}

/* Size tiers */
.tag-pill.size-sm { font-size: 0.75rem; }
.tag-pill.size-md { font-size: 0.9rem; }
.tag-pill.size-lg { font-size: 1.1rem; }
.tag-pill.size-xl { font-size: 1.3rem; }

/* Coral treatment — matches site-wide pill system */
.tag-pill {
  background: rgba(216, 90, 48, 0.12);
  border: 1px solid rgba(216, 90, 48, 0.4);
  color: #d85a30;
}
[data-theme="dark"] .tag-pill {
  background: rgba(255, 107, 74, 0.15);
  border-color: rgba(255, 107, 74, 0.4);
  color: #ff6b4a;
}

.tag-count {
  font-size: 0.75em;
  opacity: 0.55;
  font-weight: 400;
}

/* Slightly mute non-hovered pills when any pill is hovered */
.tag-cloud:has(.tag-pill:hover) .tag-pill:not(:hover) {
  opacity: 0.45;
}
</style>
