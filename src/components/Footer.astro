---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="footer-name">Galaxy Kadiyala</span>
      <p>TPM · Systems · AI · Bengaluru</p>
    </div>
    <div class="footer-links">
      <a href="https://github.com/galaxykadiyala" target="_blank" rel="noopener">GitHub</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="footer-copy">
      <span>© {year} — Built with <a href="https://astro.build" target="_blank">Astro</a></span>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--border);
  background: var(--footer-bg);
  color: var(--footer-fg);
  padding: 2.5rem 0;
  margin-top: 4rem;
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  gap: 2rem;
}

.footer-name {
  font-family: var(--sans);
  font-weight: 800;
  font-size: 1.1rem;
  display: block;
  margin-bottom: 0.25rem;
}

.footer-left p {
  font-family: var(--mono);
  font-size: 0.75rem;
  opacity: 0.5;
}

.footer-links {
  display: flex;
  gap: 1.5rem;
}

.footer-links a {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  opacity: 0.7;
  transition: opacity 0.15s;
}
.footer-links a:hover { opacity: 1; }

.footer-copy {
  font-family: var(--mono);
  font-size: 0.75rem;
  opacity: 0.4;
}
.footer-copy a { opacity: 1; text-decoration: underline; }

@media (max-width: 640px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}
</style>
