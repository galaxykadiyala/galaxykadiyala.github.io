---
const navLinks = [
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: '/projects' },
  { label: 'Resume', href: '/resume' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-glyph">GK</span>
      <span class="logo-text">Galaxy<br/>Kadiyala</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="nav-burger" aria-label="Toggle menu" onclick="this.closest('header').classList.toggle('open')">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
  </div>
</header>

<style>
.nav-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--paper);
  border-bottom: 2px solid var(--ink);
  transition: all 0.2s ease;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  gap: 2rem;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  text-decoration: none;
  flex-shrink: 0;
}

.logo-glyph {
  width: 40px;
  height: 40px;
  background: var(--ink);
  color: var(--paper);
  font-family: var(--sans);
  font-weight: 800;
  font-size: 0.85rem;
  display: grid;
  place-items: center;
  border-radius: 6px;
  letter-spacing: -0.02em;
  flex-shrink: 0;
}

.logo-text {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 0.78rem;
  line-height: 1.2;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.nav-link {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.4rem 0.75rem;
  border-radius: var(--radius);
  transition: all 0.15s;
  color: var(--ink);
  opacity: 0.6;
}

.nav-link:hover,
.nav-link.active {
  opacity: 1;
  background: var(--ink);
  color: var(--paper);
}

.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.nav-burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--ink);
  border-radius: 2px;
  transition: all 0.2s;
}

.mobile-menu {
  display: none;
  flex-direction: column;
  border-top: 1px solid rgba(0,0,0,0.1);
  padding: 1rem var(--gap);
  gap: 0.25rem;
}

.mobile-link {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 1.1rem;
  padding: 0.5rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.nav-header.open .mobile-menu { display: flex; }

@media (max-width: 640px) {
  .nav-links { display: none; }
  .nav-burger { display: flex; }
}
</style>
