---
const currentPath = Astro.url.pathname;

const primary = [
  { label: 'Projects', href: '/projects' },
  { label: 'Writing',  href: '/blog'     },
];

const secondary = [
  { label: 'About',    href: '/about',   ext: false },
  { label: 'Resume',   href: '/resume',  ext: false },
  { label: 'Contact',  href: '/contact', ext: false },
];
---

<header class="nav-header" id="nav-header">
  <div class="container nav-inner">

    <a href="/" class="nav-logo">
      <span class="logo-glyph">GK</span>
      <div class="logo-text-group">
        <span class="logo-name">Galaxy Kadiyala</span>
        <span class="logo-sub">TPM · AI · Systems</span>
      </div>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {primary.map(link => (
        <a
          href={link.href}
          class:list={[
            'nav-link',
            'nav-link--primary',
            { 'nav-link--systems': link.href === '/systems' },
            { active: currentPath.startsWith(link.href) },
          ]}
        >
          {link.label}
        </a>
      ))}

      <span class="nav-sep" aria-hidden="true"></span>

      {secondary.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', 'nav-link--secondary', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="nav-end">
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button class="nav-burger" aria-label="Toggle menu" id="nav-burger">
        <span></span><span></span><span></span>
      </button>
    </div>

  </div>

  <div class="mobile-menu" id="mobile-menu">
    {[...primary, ...secondary].map(link => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
  </div>
</header>

<script is:inline>
  (function() {
    var toggle = document.getElementById('theme-toggle');
    var burger = document.getElementById('nav-burger');
    var header = document.getElementById('nav-header');
    var mobileMenu = document.getElementById('mobile-menu');

    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    }

    toggle && toggle.addEventListener('click', function() {
      var current = document.documentElement.getAttribute('data-theme');
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });

    burger && burger.addEventListener('click', function() {
      var open = header.classList.toggle('open');
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Close mobile menu when a link is clicked
    mobileMenu && mobileMenu.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        header.classList.remove('open');
      });
    });
  })();
</script>

<style>
.nav-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--paper);
  border-bottom: 1px solid var(--border);
  transition: background-color 0.2s ease, border-color 0.2s ease;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
  gap: 1.5rem;
}

/* ── Logo ─────────────────────────────────────── */
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  text-decoration: none;
  flex-shrink: 0;
}

.logo-glyph {
  width: 36px;
  height: 36px;
  background: var(--ink);
  color: var(--paper);
  font-family: var(--sans);
  font-weight: 800;
  font-size: 0.78rem;
  display: grid;
  place-items: center;
  border-radius: 5px;
  letter-spacing: -0.01em;
  flex-shrink: 0;
  transition: background-color 0.2s ease, color 0.2s ease;
}

.logo-text-group {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.logo-name {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 0.82rem;
  line-height: 1.2;
  letter-spacing: -0.01em;
}

.logo-sub {
  font-family: var(--mono);
  font-size: 0.62rem;
  color: var(--fg-3);
  letter-spacing: 0.04em;
  line-height: 1.4;
}

/* ── Nav links ────────────────────────────────── */
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.15rem;
}

.nav-sep {
  width: 1px;
  height: 16px;
  background: var(--border);
  margin: 0 0.35rem;
  flex-shrink: 0;
}

.nav-link {
  font-family: var(--sans);
  font-weight: 500;
  font-size: 0.82rem;
  letter-spacing: 0.02em;
  padding: 0.35rem 0.65rem;
  border-radius: var(--radius);
  transition: background 0.12s ease, color 0.12s ease, opacity 0.12s ease;
  color: var(--ink);
  text-decoration: none;
  opacity: 0.5;
}

.nav-link:hover {
  opacity: 1;
  background: var(--paper-2);
}

.nav-link.active {
  opacity: 1;
  background: var(--ink);
  color: var(--paper);
}

.nav-link--primary {
  font-weight: 600;
  opacity: 0.7;
}

.nav-link--systems {
  opacity: 1;
  font-weight: 700;
}

.nav-link--secondary {
  opacity: 0.38;
  font-size: 0.76rem;
}

.nav-link--systems.active,
.nav-link--primary.active,
.nav-link--secondary.active {
  opacity: 1;
  background: var(--ink);
  color: var(--paper);
}

/* ── Right group ──────────────────────────────── */
.nav-end {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-shrink: 0;
}

/* ── Theme toggle ─────────────────────────────── */
.theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background: none;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  cursor: pointer;
  color: var(--ink);
  opacity: 0.65;
  transition: opacity 0.15s, border-color 0.15s, background 0.15s;
}

.theme-toggle:hover {
  opacity: 1;
  background: var(--paper-2);
}

/* In dark mode: show sun (click → go light). In light mode: show moon (click → go dark). */
[data-theme="dark"]  .icon-moon { display: none; }
:root:not([data-theme="dark"]) .icon-sun  { display: none; }

/* ── Burger ───────────────────────────────────── */
.nav-burger {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.nav-burger span {
  display: block;
  width: 20px;
  height: 1.5px;
  background: var(--ink);
  border-radius: 2px;
  transition: all 0.2s;
}

/* ── Mobile menu ──────────────────────────────── */
.mobile-menu {
  display: none;
  flex-direction: column;
  border-top: 1px solid var(--border);
  padding: 1rem var(--gap);
  gap: 0.15rem;
  background: var(--paper);
}

.mobile-link {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 1rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--border);
  letter-spacing: 0.01em;
  color: var(--ink);
  opacity: 0.75;
}

.mobile-link:last-child { border-bottom: none; }

.nav-header.open .mobile-menu { display: flex; }

@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-burger { display: flex; }
}

@media (max-width: 480px) {
  .logo-text-group { display: none; }
}
</style>
